import("//Meta/gn/build/libs/third_party.gni")

third_party_dependency("curl") {
  libs = [
    "curl",
    "z",
    "brotlidec",
    "brotlicommon",
    "zstd",
    "nghttp2",
    "ngtcp2",
    "ngtcp2_crypto_ossl",
    "nghttp3",
  ]
  if (current_os == "mac") {
    frameworks = [
      "SystemConfiguration.framework",
      "Security.framework",
      "CoreFoundation.framework",
      "CoreServices.framework",
    ]
  } else {
    libs += [
      "ssl",
      "crypto",
    ]
  }
}
